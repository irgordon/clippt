{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../dist",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Clippt",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "globalShortcut": {
        "all": true
      },
      "window": {
        "all": false,
        "show": true,
        "hide": true,
        "setFocus": true
      },
      "fs": {
        "all": false
      },
      "path": {
        "all": false
      },
      "shell": {
        "all": false
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.clippt.app",
      "category": "Productivity",
      "copyright": "Copyright © 2026 Clippt Contributors",
      "shortDescription": "Local-first clipboard manager",
      "longDescription": "Clippt is a local-first clipboard manager with bounded memory, opt-in persistence, and privacy-aware filtering.",
      "externalBin": [],
      "icon": [
        "icons/icon.png"
      ],
      "macOS": {
        "entitlements": "entitlements.mac.plist",
        "exceptionDomain": "",
        "frameworks": [],
        "minimumSystemVersion": "10.13",
        "providerShortName": null,
        "signingIdentity": null
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "http://timestamp.digicert.com",
        "tsp": false,
        "webviewInstallMode": {
          "type": "downloadBootstrapper"
        },
        "wix": {
          "language": "en-US"
        },
        "nsis": null
      }
    },
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "title": "Clippt",
        "label": "main",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ]
  }
}
